# Formspree Form ID für das Kontaktformular (ohne E-Mail im Quellcode)
# 1. https://formspree.io — Account anlegen, neues Formular erstellen
# 2. Im Dashboard die Ziel-E-Mail für Benachrichtigungen eintragen (bleibt bei Formspree)
# 3. Form-ID aus der URL kopieren (z.B. xyzabc aus https://formspree.io/f/xyzabc)
NEXT_PUBLIC_FORMSPREE_ID=deine_form_id_hier

# Alternative ohne .env: portfolio/lib/site-config.ts → FORMSPREE_FORM_ID_FALLBACK

# Optional: Google reCAPTCHA v3 — Site Key (Secret Key nur in Formspree/Google, nicht hier)
# In Formspree: Spam Protection → reCAPTCHA aktivieren; in Google Cloud Schlüssel für deine Domain anlegen
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=deine_site_key

# Upstash Redis für IP-Bann bei Hassrede im Kontaktformular
# 1. Gehe zu https://upstash.com und erstelle einen kostenlosen Account
# 2. Erstelle eine Redis-Datenbank
# 3. Kopiere URL und Token aus dem Dashboard
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=dein_token_hier
