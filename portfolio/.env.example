# Formspree Form ID für das Kontaktformular
# 1. Gehe zu https://formspree.io und erstelle einen kostenlosen Account
# 2. Erstelle ein neues Formular
# 3. Setze die E-Mail-Benachrichtigung auf: lucarue200@gmail.com
# 4. Kopiere die Form-ID aus der URL (z.B. xyzabc aus https://formspree.io/f/xyzabc)
NEXT_PUBLIC_FORMSPREE_ID=deine_form_id_hier

# Upstash Redis für IP-Bann bei Hassrede im Kontaktformular
# 1. Gehe zu https://upstash.com und erstelle einen kostenlosen Account
# 2. Erstelle eine Redis-Datenbank
# 3. Kopiere URL und Token aus dem Dashboard
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=dein_token_hier
